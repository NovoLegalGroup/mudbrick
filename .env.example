# Mudbrick v2 -- Environment Variables (Desktop)
# Copy to .env and customize as needed.

# Data directory for session storage (default: %APPDATA%/mudbrick)
# MUDBRICK_DATA_DIR=C:/Users/YourName/AppData/Roaming/mudbrick

# Path to Tesseract OCR binary (default: "tesseract" i.e. on PATH)
# MUDBRICK_TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# API port (default: 8000)
# MUDBRICK_API_PORT=8000

# Max version history per session (default: 50)
# MUDBRICK_MAX_VERSIONS=50

# Stale session cleanup threshold in days (default: 7)
# MUDBRICK_STALE_SESSION_DAYS=7
