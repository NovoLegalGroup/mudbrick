# Mudbrick v2 -- Environment Variables

# Backend environment: "local" uses filesystem adapters, "production" uses Vercel Blob/KV
MUDBRICK_ENV=local

# Local development: directory for session file storage
MUDBRICK_DATA_DIR=./data

# Vercel Blob (production only)
BLOB_READ_WRITE_TOKEN=

# Vercel KV / Redis (production only)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# OCR: path to Tesseract binary (local dev)
TESSERACT_CMD=tesseract

# Frontend dev server port
VITE_PORT=5173

# Backend API port (local dev)
API_PORT=8000
