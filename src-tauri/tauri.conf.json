{
  "$schema": "https://raw.githubusercontent.com/nicholascw/tauri-schema/v2/schema.json",
  "productName": "Mudbrick",
  "version": "2.0.0",
  "identifier": "com.novolegal.mudbrick",
  "build": {
    "beforeDevCommand": "pnpm --filter @mudbrick/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @mudbrick/web build",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mudbrick",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8000 http://127.0.0.1:8000; img-src 'self' blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": []
    }
  }
}
